[Unit]
Description=Lerd DNS (dnsmasq)
After=network.target

[Container]
Image=docker.io/library/alpine:latest
ContainerName=lerd-dns
PublishPort=127.0.0.1:5300:5300/udp
PublishPort=127.0.0.1:5300:5300/tcp
Volume=%h/.local/share/lerd/dnsmasq:/etc/dnsmasq.d:ro
Exec=/bin/sh -c "apk add --no-cache dnsmasq 2>/dev/null && dnsmasq --no-daemon --conf-dir=/etc/dnsmasq.d"

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
